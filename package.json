{
  "name": "major-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "./.venv/bin/python -m uvicorn main:app --reload",
    "dev": "sh -c 'python_pid=; trap \"[ -n \\\"$python_pid\\\" ] && kill $python_pid 2>/dev/null\" EXIT INT TERM; ./.venv/bin/python -m uvicorn main:app --reload & python_pid=$!; npm run dev:frontend'",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.5",
    "@fontsource-variable/playfair-display": "^5.3.0",
    "d3-hierarchy": "^3.1.2",
    "framer-motion": "^12.9.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.5",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
